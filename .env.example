# Server
PORT=5000

# MongoDB — replace placeholders with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — use a long random string in your local .env (never commit .env)
JWT_SECRET=<generate-a-long-random-secret>
JWT_EXPIRES_IN=7d

# WhatsApp — country code + number, no + sign (e.g. 91XXXXXXXXXX)
WHATSAPP_CLINIC_NUMBER=<your-clinic-whatsapp-number>

# One-time doctor admin setup key — choose a strong secret for your local .env
ADMIN_SETUP_SECRET=<choose-a-strong-setup-secret>
